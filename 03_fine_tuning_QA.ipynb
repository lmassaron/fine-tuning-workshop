   ],
   "source": "# \u2500\u2500 LoRA configuration \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\npeft_config = LoraConfig(\n    r=32,            # rank \u2013 controls the capacity of the low-rank matrices\n    lora_alpha=64,   # scaling factor: alpha/r = 2 is a commonly effective ratio\n    lora_dropout=0,  # no dropout needed \u2013 LoRA already trains very few parameters\n    bias=\"none\",     # do not train bias parameters\n    task_type=\"CAUSAL_LM\",  # next-token prediction (generative model)\n    target_modules=[         # apply LoRA to the core attention and MLP layers\n        \"q_proj\",\n        \"k_proj\",\n        \"v_proj\",\n        \"o_proj\",\n        \"gate_proj\",\n        \"up_proj\",\n        \"down_proj\",\n    ],\n)\n\n# \u2500\u2500 SFT training configuration \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\ntraining_arguments = SFTConfig(\n    output_dir=\"logs\",           # where to save checkpoints and TensorBoard logs\n    seed=params.seed,\n    num_train_epochs=2,           # 2 epochs is sufficient for LoRA on this dataset size\n    gradient_checkpointing=False, # trade compute for memory \u2013 enable if you run out of VRAM\n    per_device_train_batch_size=1,\n    gradient_accumulation_steps=8, # effective batch size = 1 \u00d7 8 = 8\n    optim=\"adamw_torch_fused\",    # memory-efficient fused AdamW\n    save_total_limit=3,            # keep only the 3 most recent checkpoints on disk\n    logging_steps=25 if DEMO else 500,\n    learning_rate=5e-5,            # conservative LR for stable LoRA fine-tuning\n    weight_decay=0.01,\n    fp16=not(is_bfloat16_supported()),  # float16 on older GPUs\n    bf16=is_bfloat16_supported(),       # bfloat16 on Ampere+\n    max_grad_norm=0.3,             # gradient clipping prevents exploding gradients\n    max_steps=-1,                  # -1 = determined by num_train_epochs\n    warmup_steps=836,              # ~10 % of total steps; ramps LR up before decay\n    eval_strategy='steps',\n    eval_steps=25 if DEMO else 500,\n    eval_accumulation_steps=1,\n    save_strategy=\"steps\",\n    save_steps=500,\n    load_best_model_at_end=True,       # reload the lowest-eval-loss checkpoint at the end\n    metric_for_best_model=\"eval_loss\",\n    lr_scheduler_type=\"cosine\",        # cosine decay: LR starts high and smoothly decreases\n    dataset_text_field=\"messages\",     # column in the dataset that contains the conversation\n    packing=False,\n    max_length=params.max_seq_length,\n    report_to=\"none\",\n)\n\n# \u2500\u2500 Trainer initialisation \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# Bringing everything together: model, data, LoRA config, tokeniser, and training args.\ntrainer = SFTTrainer(\n    model=model,\n    train_dataset=train_data,\n    eval_dataset=eval_data,\n    peft_config=peft_config,         # use LoRA: only the small adapter matrices are trained\n    processing_class=tokenizer,\n    args=training_arguments,\n)"
  },
