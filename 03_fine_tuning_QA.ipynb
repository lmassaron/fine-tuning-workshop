   "source": "# Merge the LoRA adapter back into the base model weights to produce a\n# single standalone model that can be loaded without the PEFT library.\n# merge_and_unload() is mathematically equivalent to the adapted model\n# but packages everything into the standard transformers format.\nif not DEMO:\n  print(\"\\nMerging the final model\")\n  merged_model = trainer.model.merge_and_unload()\n\n  output_path = f\"{params.OUTPUT_MODEL}\"\n  print(f\"Saving the final model to {output_path}\")\n  merged_model.save_pretrained(output_path)  # saves full weights (~2 GB)\n  tokenizer.save_pretrained(output_path)\n\n  repo_name = \"lmassaron/\" + output_path\n\n  # Push the MERGED model (not the adapter) to the Hub.\n  # This is the model that notebooks 04 will load for evaluation.\n  merged_model.push_to_hub(repo_name)\n  tokenizer.push_to_hub(repo_name)\n\n  print(f\"Model and tokenizer pushed to {repo_name}\")"
  }
